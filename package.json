{
    "activationEvents": [
        "onFileSystem:file"
    ],
    "categories": [
        "Other"
    ],
    "contributes": {
        "commands": [
            {
                "category": "File Shortcut",
                "command": "fileShortcut.showFileList",
                "icon": "$(search)",
                "title": "Open Files List"
            },
            {
                "category": "File Shortcut",
                "command": "fileShortcut.addCurrentFile",
                "icon": "$(add)",
                "title": "Add Current File To List"
            },
            {
                "command": "fileShortcut.addCurrentFileContext",
                "icon": "$(add)",
                "title": "File Shortcut: Add Current File To List"
            },
            {
                "category": "File Shortcut",
                "command": "fileShortcut.deleteFile",
                "icon": "$(chrome-close)",
                "title": "Delete Current File From List"
            },
            {
                "category": "File Shortcut",
                "command": "fileShortcut.toggleFileAlias",
                "icon": "$(word-wrap)",
                "title": "Add/Remove File Alias"
            },
            {
                "category": "File Shortcut",
                "command": "fileShortcut.deleteGroup",
                "icon": "$(chrome-close)",
                "title": "Delete Group"
            },
            {
                "command": "fileShortcut.changeFileGroup",
                "icon": "$(ungroup-by-ref-type)",
                "title": "Change File Group"
            },
            {
                "command": "fileShortcut.renameGroup",
                "icon": "$(edit)",
                "title": "Rename Group"
            },
            {
                "command": "fileShortcut.openFile",
                "title": "Open File"
            },
            {
                "command": "fileShortcut.sort",
                "icon": "$(sort-precedence)",
                "title": "Change List Sorting"
            },
            {
                "command": "fileShortcut.DisplayFileNameInListAs",
                "icon": "$(whole-word)",
                "title": "Change File Names Display"
            }
        ],
        "configuration": {
            "properties": {
                "fileShortcut.DisplayFileNameInListAs": {
                    "default": 1,
                    "description": "change how to display file labels in treeview",
                    "enum": [
                        1,
                        2
                    ],
                    "enumDescriptions": [
                        "name + alias",
                        "alias only"
                    ],
                    "type": "number"
                },
                "fileShortcut.hideSidebarTimeOut": {
                    "default": 0.5,
                    "description": "in seconds, toggle sidebar after file is opened (0 == do nothing)\n 'only works when file is opened from treeview'",
                    "type": "number"
                },
                "fileShortcut.list": {
                    "default": [],
                    "description": "List of favorite Files. e.g /home/user/cheatsheet.md",
                    "items": {
                        "type": [
                            "string",
                            "object"
                        ]
                    },
                    "type": "array",
                    "uniqueItems": true
                },
                "fileShortcut.OpenInNewGroup": {
                    "default": true,
                    "description": "open files in new group/column next to current",
                    "type": "boolean"
                },
                "fileShortcut.sort": {
                    "default": "length",
                    "description": "sort treeview list alphabetically or by text length",
                    "enum": [
                        "alpha",
                        "length"
                    ],
                    "type": "string"
                },
                "fileShortcut.unGroupedListName": {
                    "default": "♠❤♣♦",
                    "description": "un-grouped list name",
                    "type": "string"
                }
            },
            "title": "File Shortcuts",
            "type": "object"
        },
        "menus": {
            "commandPalette": [
                {
                    "command": "fileShortcut.addCurrentFile",
                    "when": "fscEnabled"
                },
                {
                    "command": "fileShortcut.toggleFileAlias",
                    "when": "false"
                },
                {
                    "command": "fileShortcut.openFile",
                    "when": "false"
                },
                {
                    "command": "fileShortcut.sort",
                    "when": "false"
                },
                {
                    "command": "fileShortcut.DisplayFileNameInListAs",
                    "when": "false"
                },
                {
                    "command": "fileShortcut.changeFileGroup",
                    "when": "false"
                },
                {
                    "command": "fileShortcut.renameGroup",
                    "when": "false"
                },
                {
                    "command": "fileShortcut.deleteFile",
                    "when": "false"
                },
                {
                    "command": "fileShortcut.deleteGroup",
                    "when": "false"
                }
            ],
            "editor/context": [
                {
                    "command": "fileShortcut.addCurrentFileContext",
                    "group": "fileshortcut",
                    "when": "fscEnabled"
                }
            ],
            "explorer/context": [
                {
                    "command": "fileShortcut.addCurrentFileContext",
                    "group": "fileshortcut",
                    "when": "!explorerResourceIsFolder"
                }
            ],
            "view/item/context": [
                {
                    "command": "fileShortcut.deleteFile",
                    "group": "inline",
                    "when": "(view == fs_list_workspace || view == fs_list_global) && viewItem =~ /(child|default-child)/"
                },
                {
                    "command": "fileShortcut.toggleFileAlias",
                    "group": "inline",
                    "when": "(view == fs_list_workspace || view == fs_list_global) && viewItem == child"
                },
                {
                    "command": "fileShortcut.changeFileGroup",
                    "group": "inline",
                    "when": "(view == fs_list_workspace || view == fs_list_global) && viewItem =~ /(child|default-child)/"
                },
                {
                    "command": "fileShortcut.deleteGroup",
                    "group": "inline",
                    "when": "(view == fs_list_workspace || view == fs_list_global) && viewItem == parent"
                },
                {
                    "command": "fileShortcut.renameGroup",
                    "group": "inline",
                    "when": "(view == fs_list_workspace || view == fs_list_global) && viewItem == parent"
                }
            ],
            "view/title": [
                {
                    "command": "fileShortcut.addCurrentFile",
                    "group": "navigation",
                    "when": "(view == fs_list_workspace || view == fs_list_global) && fscEnabled"
                },
                {
                    "command": "fileShortcut.sort",
                    "group": "navigation",
                    "when": "(view == fs_list_workspace || view == fs_list_global) && fscHasFiles"
                },
                {
                    "command": "fileShortcut.DisplayFileNameInListAs",
                    "group": "navigation",
                    "when": "(view == fs_list_workspace || view == fs_list_global) && fscHasFiles"
                },
                {
                    "command": "fileShortcut.showFileList",
                    "group": "navigation",
                    "when": "(view == fs_list_workspace || view == fs_list_global) && fscHasFiles"
                }
            ]
        },
        "views": {
            "file-shortcut": [
                {
                    "icon": "img/file.svg",
                    "id": "fs_list_workspace",
                    "name": "Workspace Files"
                },
                {
                    "icon": "img/file.svg",
                    "id": "fs_list_global",
                    "name": "Global Files"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "icon": "img/file.svg",
                    "id": "file-shortcut",
                    "title": "File Shortcut"
                }
            ]
        }
    },
    "description": "add/open/delete your favorite file list",
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/vscode": "^1.100.0",
        "esbuild": "^0.27.4",
        "typescript": "^5.9.3"
    },
    "displayName": "File Shortcut",
    "engines": {
        "vscode": "^1.100.0"
    },
    "icon": "img/file.png",
    "keywords": [
        "file",
        "bookmark",
        "shortcut"
    ],
    "main": "./out/main",
    "name": "file-shortcut",
    "publisher": "ctf0",
    "repository": "https://github.com/ctf0/vscode-file-shortcut",
    "scripts": {
        "esbuild": "npm run esbuild-base -- --sourcemap",
        "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
        "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
        "vscode:prepublish": "npm run esbuild-base -- --pure:console.log --minify",
        "watch": "npm run esbuild"
    },
    "version": "0.4.3"
}
